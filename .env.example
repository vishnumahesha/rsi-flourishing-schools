# ---------------------------------------------------------------------------
# RSI Flourishing Schools Platform — Environment Variables
# Copy this file to .env.local and fill in values. NEVER commit .env.local.
# ---------------------------------------------------------------------------

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the browser. Used by server actions / route handlers.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for auth redirects + metadata). e.g. https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI provider key (Anthropic). If absent, AI features return safe mock responses.
AI_PROVIDER_API_KEY=
# Optional: override the model used for analysis/coach
AI_MODEL=claude-sonnet-4-6
